<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Onke Mbingeleli | Portfolio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Inter:wght@400;500&family=Roboto:wght@500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

  <!-- Header -->
  <header>
    <div class="container">
      <nav>
        <div class="logo">Onke Mbingeleli</div>
        <div class="nav-links">
          <a href="#about">About</a>
          <a href="#skills">Skills</a>
          <a href="#projects">Projects</a>
          <a href="#certifications">Certifications</a>
          <a href="#contact">Contact</a>
        </div>
      </nav>
    </div>
  </header>

<!-- Hero -->
  <section id="hero" class="container">
    <div class="hero">
      <div class="hero-img">
        <img src="assets/profile.jpg" alt="Portrait of Onke Mbingeleli" class="profile-photo">
      </div>
      <div class="hero-content">
        <span class="eyebrow">Available for junior web developer opportunities</span>
        <h1>Onke Mbingeleli</h1>
        <p class="accent-text">Entry-Level Web Developer</p>
        <p class="hero-summary">I build clean, responsive websites and simple web apps with a strong focus on usability, structure, and modern frontend development.</p>
        <div class="hero-actions">
          <a href="#projects" class="btn btn-primary">View Projects</a>
          <a href="#contact" class="btn btn-ghost">Contact Me</a>
        </div>
        <div class="hero-highlights">
          <div class="highlight-pill">Frontend Development</div>
          <div class="highlight-pill">Responsive Design</div>
          <div class="highlight-pill">GitHub Projects</div>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="container">
    <h2 class="section-title">About Me</h2>
    <div class="about-grid">
      <div class="about-img">
        <div class="about-panel">
          <p class="about-panel-label">Quick Snapshot</p>
          <h3>Short, clear, and ready to present</h3>
          <p>I focus on the skills and projects that matter most so recruiters can understand my value quickly.</p>
        </div>
      </div>
      <div>
        <p>I am a motivated developer with a growing foundation in HTML, CSS, JavaScript, React, and Node.js. I enjoy building practical digital experiences, learning fast, and turning ideas into polished, user-friendly interfaces.</p>
        <div class="highlight-cards">
          <div class="card"><h4>Focus</h4><p>Modern, responsive user interfaces</p></div>
          <div class="card"><h4>Stack</h4><p>HTML, CSS, JavaScript, React, Node.js</p></div>
          <div class="card"><h4>Goal</h4><p>Grow into a strong full-stack developer</p></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills" class="container">
    <h2 class="section-title">Skills</h2>
    <div class="skills-grid">
      <div class="skill-category">
        <h3>Frontend</h3>
        <div class="skill-chip-group">
          <span class="skill-chip">HTML5</span>
          <span class="skill-chip">CSS3</span>
          <span class="skill-chip">JavaScript</span>
          <span class="skill-chip">React</span>
        </div>
      </div>
      <div class="skill-category">
        <h3>Backend</h3>
        <div class="skill-chip-group">
          <span class="skill-chip">Node.js</span>
          <span class="skill-chip">REST APIs</span>
          <span class="skill-chip">Basic CRUD</span>
        </div>
      </div>
      <div class="skill-category">
        <h3>Tools</h3>
        <div class="skill-chip-group">
          <span class="skill-chip">Git</span>
          <span class="skill-chip">GitHub</span>
          <span class="skill-chip">Figma</span>
          <span class="skill-chip">VS Code</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects" class="container">
    <h2 class="section-title">Projects</h2>
    <div class="projects-carousel">
      <article class="project-card">
        <div class="project-img"></div>
        <div class="project-info">
          <h3>E-Commerce Dashboard</h3>
          <p>Responsive dashboard interface built to present business data clearly and improve usability across devices.</p>
          <div class="project-tags"><span class="tag">React</span><span class="tag">UI Design</span></div>
          <div class="project-links"><a href="#" class="btn btn-ghost">Live Site</a><a href="#" class="btn btn-ghost">GitHub</a></div>
        </div>
      </article>
      <article class="project-card">
        <div class="project-img"></div>
        <div class="project-info">
          <h3>Task Manager App</h3>
          <p>Task tracking application focused on clean interaction, simple workflows, and organized productivity features.</p>
          <div class="project-tags"><span class="tag">JavaScript</span><span class="tag">Node.js</span></div>
          <div class="project-links"><a href="#" class="btn btn-ghost">Live Site</a><a href="#" class="btn btn-ghost">GitHub</a></div>
        </div>
      </article>
      <article class="project-card">
        <div class="project-img"></div>
        <div class="project-info">
          <h3>Portfolio Website</h3>
          <p>Personal portfolio designed to introduce my work fast, highlight strengths, and present a professional online brand.</p>
          <div class="project-tags"><span class="tag">PHP</span><span class="tag">CSS</span></div>
          <div class="project-links"><a href="#" class="btn btn-ghost">Live Site</a><a href="#" class="btn btn-ghost">GitHub</a></div>
        </div>
      </article>
    </div>
  </section>

  <!-- Certifications -->
  <section id="certifications" class="container">
    <h2 class="section-title">Certifications</h2>
    <div class="cert-grid">
      <div class="cert-card">
        <div class="cert-badge" style="background: #005A9C;">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="white"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14h-2v-4H6v-2h4V7h2v4h4v2h-4v4z"/></svg>
        </div>
        <div>
          <h3>Cloud Essentials</h3>
          <p class="cert-org">IBM</p>
          <p class="cert-date">Issued: February 2026</p>
          <a href="https://www.credly.com/badges/71888e7d-5594-4ef4-b764-1672be10d797" class="btn btn-ghost cert-link" target="_blank" rel="noopener noreferrer">View Badge</a>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-badge" style="background: #FF6B35;">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="white"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
        </div>
        <div>
          <h3>Data Capturing</h3>
          <p class="cert-org">QUEST COMPUTER SKILLS CENTRE</p>
          <p class="cert-date">Issued: July 2024</p>
          <p style="font-size: 0.85rem; margin-top: 0.5rem; color: var(--accent);">Alpha Numeric: 23 wpm (95%) | Numeric: 88 kpm (96%)</p>
          <span class="btn btn-ghost cert-link cert-link-muted">Certificate available on request</span>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-badge" style="background: #005073;">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="white"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
        </div>
        <div>
          <h3>Introduction to Cybersecurity</h3>
          <p class="cert-org">Cisco</p>
          <p class="cert-date">Issued: February 2026</p>
          <a href="https://www.credly.com/badges/d66bc7e3-aa4b-4c31-a67d-e60c0f621664" class="btn btn-ghost cert-link" target="_blank" rel="noopener noreferrer">View Badge</a>
        </div>
      </div>

      <div class="cert-card">
        <div class="cert-badge" style="background: #005073;">
          <svg width="30" height="30" viewBox="0 0 24 24" fill="white"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/></svg>
        </div>
        <div>
          <h3>Introduction to Data Science</h3>
          <p class="cert-org">Cisco</p>
          <p class="cert-date">Issued: February 2026</p>
          <a href="https://www.credly.com/badges/d4eddc01-71f8-4466-aedf-915d4099fc53" class="btn btn-ghost cert-link" target="_blank" rel="noopener noreferrer">View Badge</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="container">
    <h2 class="section-title">Contact</h2>
    <div class="contact-grid">
      <div>
        <p class="contact-copy">If you are looking for a junior developer who is eager to learn, build, and contribute, let's connect.</p>
        <div class="contact-actions">
          <a href="mailto:onke@example.com" class="btn btn-primary">Email Me</a>
          <a href="#" class="btn btn-ghost">Download CV</a>
        </div>
      </div>
      <ul class="social-links">
        <li><div class="social-icon">L</div><span>LinkedIn Profile</span></li>
        <li><div class="social-icon">G</div><span>GitHub Portfolio</span></li>
        <li><div class="social-icon">E</div><span>onke@example.com</span></li>
      </ul>
    </div>
  </section>

</body>
</html>

